<WatchFace
    height="450"
    width="450">
    <Metadata
        key="CLOCK_TYPE"
        value="DIGITAL" />
    <Metadata
        key="PREVIEW_TIME"
        value="10:08:32" />
    <Scene>
        <DigitalClock
            height="450"
            width="450"
            x="0"
            y="0">
            <!-- Main time (24-hour), interactive mode -->
            <PartText
                height="160"
                width="450"
                x="0"
                y="145">
                <Variant
                    mode="AMBIENT"
                    target="alpha"
                    value="0" />
                <Text align="CENTER">
                    <Font
                        color="#ffffffff"
                        family="dseg14classic_regular"
                        size="96">
                        <Template><![CDATA[%02d:%02d]]>
                            <Parameter expression="[HOUR_0_23]" />
                            <Parameter expression="[MINUTE]" />
                        </Template>
                    </Font>
                </Text>
            </PartText>
            <!-- Dimmed time (24-hour), ambient (always-on) mode -->
            <PartText
                alpha="0"
                height="160"
                width="450"
                x="0"
                y="145">
                <Variant
                    mode="AMBIENT"
                    target="alpha"
                    value="255" />
                <Text align="CENTER">
                    <Font
                        color="#ff9aa0a6"
                        family="dseg14classic_regular"
                        size="96">
                        <Template><![CDATA[%02d:%02d]]>
                            <Parameter expression="[HOUR_0_23]" />
                            <Parameter expression="[MINUTE]" />
                        </Template>
                    </Font>
                </Text>
            </PartText>
        </DigitalClock>
    </Scene>
</WatchFace>
